{
  "entities": {
    "medicalRecord": {
      "title": "Medical Record",
      "description": "Patient medical record (Carcinome Différencié de la Thyroïde) — 38 fields aligned with Fiche_Guide_CDT.xlsx",
      "type": "object",
      "properties": {
        "numeroDossier": { "type": "string", "pattern": "^[A-Z0-9]{3}/[0-9]{2}$" },
        "nom": { "type": "string" },
        "prenoms": { "type": "string" },
        "sexe": { "type": "string", "enum": ["", "Féminin", "Masculin"] },
        "ddn": { "type": "string" },
        "wilaya": { "type": "string" },
        "atcdFamCdt": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "atcdFamCancer": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "atcdPersCancer": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "ageDgc": { "type": "number" },
        "cdt": { "type": "string", "enum": ["", "CPT", "CVT", "COT"] },
        "variante": { "type": "string", "enum": ["", "Vésiculaire", "Oncocytaire", "Trabéculaire solide", "NIFTP"] },
        "taille": { "type": "string", "enum": ["", "<2", "=2", ">2"] },
        "ec": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "macroMicro": { "type": "string", "enum": ["", "Microscopique", "Macroscopique"] },
        "ev": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "evCount": { "type": "string", "enum": ["", "< 4", "≥ 4"] },
        "mitoses": { "type": "string", "enum": ["", "<3", "≥3", "Non précisé"] },
        "hgie": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "nse": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "filetNerv": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "r": { "type": "string", "enum": ["", "R0", "R1", "R2"] },
        "t": { "type": "string", "enum": ["", "T1", "T1a", "T1b", "T2", "T3a", "T3b", "T4"] },
        "n": { "type": "string", "enum": ["", "N0", "Nx", "N1a", "N1b"] },
        "m": { "type": "string", "enum": ["", "M0", "Mx", "M1"] },
        "chir": { "type": "string", "enum": ["", "TT", "TST", "TP"] },
        "cg": { "type": "string", "enum": ["", "Oui", "Non", "Non précisé"] },
        "tps": { "type": "string", "enum": ["", "1", "2", "3"] },
        "dgcI1": { "type": "number" },
        "chirI1": { "type": "number" },
        "nbreCures": { "type": "number" },
        "actCum": { "type": "number" },
        "suivi": { "type": "number" },
        "rep2ans": { "type": "string", "enum": ["", "RC", "Récidive", "RP", "RS", "PD", "Perdu de vue"] },
        "rep5ans": { "type": "string", "enum": ["", "RC", "Récidive", "RP", "RS", "PD", "Perdu de vue"] },
        "rep10ans": { "type": "string", "enum": ["", "RC", "Récidive", "RP", "RS", "PD", "Perdu de vue"] },
        "dcd": { "type": "string", "enum": ["", "Oui", "Non", "Perdu de vue"] },
        "dcdAge": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "createdAt", "updatedAt", "numeroDossier", "nom", "prenoms"]
    },
    "recordVersion": {
      "title": "Medical Record Version",
      "description": "Snapshot of a medical record on each update — audit trail",
      "type": "object",
      "properties": {
        "recordId": { "type": "string" },
        "snapshot": { "type": "string" },
        "editedBy": { "type": "string" },
        "editedByEmail": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["recordId", "snapshot", "editedBy", "createdAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Admin users",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "user": {
      "title": "User",
      "description": "Registered users",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "log": {
      "title": "Log",
      "description": "Activity logs",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["action", "userId", "userEmail", "timestamp"]
    },
    "draft": {
      "title": "Draft",
      "description": "Medical record draft",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "draftData": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "draftData", "updatedAt"]
    }
  },
  "firestore": {
    "records/{recordId}": {
      "schema": { "$ref": "#/entities/medicalRecord" },
      "description": "Medical form submissions."
    },
    "records/{recordId}/versions/{versionId}": {
      "schema": { "$ref": "#/entities/recordVersion" },
      "description": "Audit-trail snapshots created on every update."
    },
    "drafts/{draftId}": {
      "schema": { "$ref": "#/entities/draft" },
      "description": "Per-user draft form data. draftId === userId."
    },
    "admins/{adminId}": {
      "schema": { "$ref": "#/entities/admin" },
      "description": "Admin role assignments. adminId === userId."
    },
    "users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "Registered application users."
    },
    "logs/{logId}": {
      "schema": { "$ref": "#/entities/log" },
      "description": "Application activity logs."
    }
  }
}
