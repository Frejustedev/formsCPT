# Email du super-administrateur (un seul, par défaut agbotonfrejuste@gmail.com)
# Cet utilisateur a tous les droits admin sans avoir besoin d'être inscrit dans la collection /admins.
NEXT_PUBLIC_SUPER_ADMIN_EMAIL="agbotonfrejuste@gmail.com"

# Optionnel — clé Gemini AI Studio (utilisée si vous activez les fonctionnalités IA).
# Laissez vide si vous n'utilisez pas l'IA.
GEMINI_API_KEY=""

# Optionnel — URL publique de l'application (utilisé par AI Studio en production).
APP_URL=""

# Optionnel — désactive le HMR pendant les éditions (utilisé en mode AI Studio).
DISABLE_HMR=""
