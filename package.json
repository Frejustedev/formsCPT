{
  "name": "registre-cdt",
  "version": "1.0.0",
  "private": true,
  "description": "Registre Cancer Thyroïde — application portable (Windows / Android / iOS)",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build:next": "next build",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "next clean && rimraf out dist electron-out",
    "electron:dev": "cross-env ELECTRON_DEV=true concurrently -k \"next dev\" \"wait-on http://localhost:3000 && electron electron/main.cjs\"",
    "electron:build": "next build && electron-builder --win portable --publish never",
    "electron:dir": "next build && electron-builder --win portable --dir --publish never",
    "mobile:sync": "next build && cap sync",
    "mobile:android": "next build && cap sync android && cap open android",
    "mobile:ios": "next build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@capacitor-community/sqlite": "^6.0.2",
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/ios": "^6.2.0",
    "@hookform/resolvers": "^5.2.1",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "^15.4.9",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.74.0",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "rimraf": "^6.0.1",
    "tailwindcss": "4.1.11",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "^2.1.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.registrecdt.app",
    "productName": "Registre CDT",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "RegistreCDT-${version}-portable.exe"
    },
    "portable": {
      "artifactName": "RegistreCDT-${version}-portable.exe",
      "unpackDirName": false
    },
    "asar": true
  }
}
